{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lukeh-xyz",
  "compatibility_date": "2026-05-21",
  "build": {
    "command": "bun run build:all"
  },
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "public"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
