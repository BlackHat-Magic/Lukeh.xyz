{
  "name": "lukeh.xyz",
  "version": "0.2.0",
  "description": "portfolio website",
  "homepage": "https://github.com/BlackHat-Magic/LukeH.xyz#readme",
  "bugs": {
    "url": "https://github.com/BlackHat-Magic/LukeH.xyz/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BlackHat-Magic/LukeH.xyz.git"
  },
  "license": "AGPL-3.0",
  "author": "BlackHat-Magic (Luke Henderson)",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "build:ts": "bun run build.ts",
    "build:css": "bunx @tailwindcss/cli -i ./static/css/main.css -o ./public/dist/main.css --minify",
    "build:assets": "cp -r static/images public/images && cp static/dist/main.css public/dist/main.css 2>/dev/null; true",
    "build:all": "bun run build:ts && bun run build:css && bun run build:assets",
    "watch": "concurrently --names ts,css \"bun run build.ts --watch\" \"bunx @tailwindcss/cli -i ./static/css/main.css -o ./public/dist/main.css --watch --minify\"",
    "dev": "bun run watch",
    "check": "./checks.sh",
    "deploy": "wrangler deploy",
    "preview": "wrangler dev",
    "clean": "rm -rf public/js/*.js public/dist/*.css",
    "test": "echo \"No tests yet\" && exit 1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/cli": "^4.1.18",
    "@types/node": "^25.9.1",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "wrangler": "^4.93.1"
  }
}
